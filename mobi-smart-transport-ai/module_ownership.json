    "윤현섭": {
      "github": "Yoonhsub",
      "owned_paths": [
        "apps/passenger_app/**",
        "apps/driver_app/**"
      ],
      "primary_responsibility": "Flutter 사용자/기사 앱 UI, STT/TTS, 접근성, API 렌더링"
    },
    "안준환": {
      "github": "ajh1206",
      "owned_paths": [
        "packages/mobile_sensors/**"
      ],
      "primary_responsibility": "BLE 비콘, RSSI 거리 추정, 스마트폰 방향 센서. 4월에는 헤드트래킹 제외"
    },
    "심현석": {
      "github": "loremipsum0116",
      "owned_paths": [
        "backend/api/**",
        "infrastructure/firebase/**"
      ],
      "primary_responsibility": "FastAPI, Firebase RTDB, FCM, 지오펜싱, 기사-승객 매칭"
    },
