# MOBI project .gitignore

# =========================
# OS / Editor
# =========================
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/
*.iml

# =========================
# Environment / secrets
# =========================
.env
*.env
.env.*
!.env.example
secrets/
secret/
credentials/
serviceAccountKey.json
firebase-service-account.json
*service-account*.json
*.pem
*.key
*.p12
*.pfx

# =========================
# Python
# =========================
__pycache__/
*.py[cod]
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
.venv/
venv/
env/
ENV/
pip-wheel-metadata/
dist/
build/
*.egg-info/

# =========================
# FastAPI / backend logs
# =========================
*.log
logs/
uvicorn.log

# =========================
# Flutter / Dart
# =========================
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
.pub-cache/
.pub/
build/
coverage/
android/.gradle/
android/app/build/
ios/Pods/
ios/.symlinks/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Flutter/ephemeral/
macos/Flutter/ephemeral/
linux/flutter/ephemeral/
windows/flutter/ephemeral/

# Generated Dart files, if any
*.g.dart
*.freezed.dart

# Keep lockfiles unless project later decides otherwise
# pubspec.lock

# =========================
# Node / Web tooling
# =========================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# =========================
# Firebase
# =========================
.firebase/
firebase-debug.log
firestore-debug.log
database-debug.log
ui-debug.log
.runtimeconfig.json

# =========================
# Google Cloud
# =========================
.gcloud/
application_default_credentials.json

# =========================
# AI / ML artifacts
# =========================
ai_vision/datasets/
ai_vision/raw_data/
ai_vision/processed_data/
ai_vision/models/*.tflite
ai_vision/models/*.onnx
ai_vision/models/*.pt
ai_vision/models/*.pth
ai_vision/models/*.weights
ai_vision/runs/
*.ckpt

# =========================
# Large media files
# =========================
*.mp4
*.mov
*.avi
*.mkv
*.wav
*.mp3
*.flac

# Allow documentation images if intentionally added
# !docs/images/*.png

# =========================
# Archives
# =========================
*.zip
*.tar
*.tar.gz
*.7z
*.rar

# =========================
# Temporary files
# =========================
tmp/
temp/
.cache/
.cache-*/
*.tmp
*.bak
*.orig

# =========================
# Test artifacts
# =========================
test-results/
reports/
junit.xml

# =========================
# Local generated package outputs
# =========================
mobi_required_docs_step_*/
mobi_final_required_package/
