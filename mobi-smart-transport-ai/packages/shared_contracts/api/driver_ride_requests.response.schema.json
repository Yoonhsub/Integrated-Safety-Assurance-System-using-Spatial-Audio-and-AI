{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "DriverRideRequestsResponse",
  "type": "object",
  "required": [
    "driverId",
    "requests"
  ],
  "properties": {
    "driverId": {
      "type": "string",
      "minLength": 1,
      "pattern": "\\S"
    },
    "requests": {
      "type": "array",
      "items": {
        "$ref": "ride_request.schema.json"
      }
    }
  },
  "additionalProperties": false
}
