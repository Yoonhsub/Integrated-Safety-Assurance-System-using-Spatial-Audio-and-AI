{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "GeofenceCheckResponse",
  "type": "object",
  "required": [
    "status",
    "message",
    "shouldSpeak",
    "shouldVibrate"
  ],
  "properties": {
    "status": {
      "type": "string",
      "enum": [
        "SAFE",
        "WARNING",
        "DANGER",
        "OUT_OF_AREA",
        "UNKNOWN"
      ]
    },
    "message": {
      "type": "string"
    },
    "shouldSpeak": {
      "type": "boolean"
    },
    "shouldVibrate": {
      "type": "boolean"
    },
    "eventId": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
