APP_ENV=development
LOG_LEVEL=debug

# Firebase (데모 프로젝트 예시: mobi-project-3c2da)
# 실제 RTDB 쓰기는 서비스 계정 json 이 있어야 활성화되며, 없으면 mock fallback 으로 동작합니다.
FIREBASE_PROJECT_ID=mobi-project-3c2da
FIREBASE_DATABASE_URL=https://mobi-project-3c2da-default-rtdb.firebaseio.com
FIREBASE_SERVICE_ACCOUNT_PATH=./backend/api/secrets/firebase-service-account.json
FIREBASE_STORAGE_BUCKET=mobi-project-3c2da.appspot.com
# 서비스 계정이 준비되면 false 로 두고 실제 연결, 강제 mock 을 원하면 true
FIREBASE_USE_MOCK=false

FCM_ENABLED=false
FCM_USE_MOCK=true
FCM_TEST_USER_TOKEN=
FCM_TEST_DRIVER_TOKEN=

PUBLIC_DATA_API_KEY=
PUBLIC_DATA_BASE_URL=https://apis.data.go.kr
PUBLIC_DATA_CITY_CODE=
PUBLIC_DATA_USE_MOCK=true
CHEONGJU_BUS_STOPS_ENABLED=false
CHEONGJU_BUS_STOPS_BASE_URL=https://api.odcloud.kr/api
CHEONGJU_BUS_STOPS_PATH=/15041896/v1/uddi:083f11f7-5067-429b-a75d-e32f94269aaf
# Comma-separated route numbers to inspect when live RoutePlan needs route sequences.
CHEONGJU_ROUTE_PLAN_ROUTE_NOS=502,823,862,863,864
# JSON map override, for example: {"862":{"first":"05:40","last":"22:50"}}
CHEONGJU_ROUTE_SERVICE_WINDOWS=
CHEONGJU_DEFAULT_ROUTE_SERVICE_WINDOW=05:30~23:30
CHEONGJU_TIMEZONE=Asia/Seoul
CHEONGJU_NEAR_DESTINATION_PLACE_METERS=120
CHEONGJU_NEAR_DESTINATION_STOP_METERS=80
# Optional server-side local/place search for arbitrary place names and addresses.
# Never expose this key in Flutter; backend calls Kakao Local API directly.
KAKAO_LOCAL_SEARCH_ENABLED=false
KAKAO_REST_API_KEY=
LOCAL_SEARCH_TIMEOUT_SECONDS=5.0

# Optional server-side ODsay public-transit planner.
# Keep the API key on the backend only. Set ODSAY_ENABLED=true for live requests.
ODSAY_ENABLED=false
ODSAY_API_KEY=
ODSAY_BASE_URL=https://api.odsay.com
ODSAY_TIMEOUT_SECONDS=8.0
# Local development can call a gateway instead of ODsay directly.
ODSAY_USE_GATEWAY=false
ODSAY_GATEWAY_URL=
ODSAY_GATEWAY_TOKEN=

BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://localhost:5173,http://127.0.0.1:5173

API_BASE_URL=http://127.0.0.1:8000
# 실제 Firebase/데이터 연결을 원하면 false
USE_MOCK_DATA=false

DEFAULT_BEACON_TX_POWER=-59
RSSI_SMOOTHING_WINDOW=5

AI_VISION_USE_MOCK=true
AI_VISION_MODEL_PATH=./ai_vision/models/model.tflite
# V3 guidance demo
V3_API_BASE_URL=http://127.0.0.1:8000
GEMINI_API_KEY=
GEMINI_FLASH_MODEL=gemini-2.5-flash
GEMINI_PRO_MODEL=gemini-2.5-pro
GEMINI_TTS_MODEL=gemini-3.1-flash-tts-preview
GEMINI_TTS_VOICE=Sulafat
